{
  "version": 2,
  "name": "ai-chatbot",
  "root": ".",
  "builds": [
    {
      "src": "backend/app/api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/.next"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/app/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "env": {
    "PYTHONPATH": "/vercel/path0/backend"
  },
  "functions": {
    "backend/app/api/index.py": {
      "runtime": "python3.9",
      "maxDuration": 30
    }
  },
  "installCommand": "cd backend && pip install -r requirements-vercel.txt"
}
